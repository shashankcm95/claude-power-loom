node_modules/
.DS_Store
*.log

# Local Claude Code working dir (session state, plans, agent worktrees). Nothing
# here is tracked; gitignored to prevent accidental commits + stale agent-worktree
# dupes polluting glob-based test discovery (v3.4 phase-close FLAG-4).
.claude/

# Swarm run state (per-run findings, not for version control)
swarm/run-state/

# Bench run artifacts (Claude's outputs during scenario runs — cli.js,
# cli.test.js, snapshots, stream.jsonl, metrics.json). Useful locally for
# debugging but never for version control. Excluded from T80 markdownlint
# and T84 ESLint via --ignore-pattern at invocation (v2.6.1).
bench/runs/

# Local-only authored content (blog drafts, etc.) — kept on disk for the
# author but not tracked in the repo.
content/

# Note: mempalace.yaml and entities.json ARE tracked — they ship as default
# rooms/people for the toolkit. Per-project users can override locally.
