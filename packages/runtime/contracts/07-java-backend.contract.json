    "budget": {
      "tokens": 35000,
      "extensible": true,
      "maxExtensions": 1,
      "extensionAmount": 15000
    }
  },
  "functional": [
    {
      "id": "F1",
      "check": "outputContainsFrontmatter",
      "required": true
    },
    {
      "id": "F2",
      "check": "frontmatterHasFields",
      "args": {
        "fields": [
          "id",
          "role",
          "depth",
          "parent",
          "persona",
          "identity"
        ]
      },
      "required": true
    },
    {
      "id": "F3",
      "check": "minFindings",
      "args": {
        "min": 2
      },
      "required": true
    },
    {
      "id": "F4",
      "check": "hasFileCitations",
      "args": {
        "min": 4
      },
      "required": true
    },
    {
      "id": "F5",
      "check": "hasSeveritySections",
      "args": {
        "severities": [
          "CRITICAL",
          "HIGH",
          "MEDIUM",
          "LOW"
        ]
      },
      "required": true
    },
    {
      "id": "F6",
      "check": "containsKeywords",
      "args": {
        "keywords": [
          "spring"
        ]
      },
      "required": false
    },
    {
      "id": "F7",
      "check": "noUnrolledLoops",
      "args": {
        "maxRepetitions": 5
      },
      "required": true
    },
    {
      "id": "F8",
      "check": "noExcessiveNesting",
      "args": {
        "maxDepth": 4
      },
      "required": true
    },
    {
      "id": "F9",
      "check": "kb_scope_consumed",
      "required": true
    }
  ],
  "antiPattern": [
    {
      "id": "A1",
      "check": "claimsHaveEvidence",
      "severity": "fail"
    },
    {
      "id": "A2",
      "check": "noTextSimilarityToPriorRun",
      "args": {
        "threshold": 0.6
      },
      "severity": "warn"
    },
    {
      "id": "A3",
      "check": "noTemplateRepetition",
      "args": {
        "minVariation": 0.3
      },
      "severity": "warn"
    },
    {
      "id": "A4",
      "check": "noPaddingPhrases",
      "severity": "fail"
    },
    {
      "id": "A5",
      "check": "acknowledgesFallback",
      "severity": "warn"
    }
  ],
  "fallbackAcceptable": [
    "No JVM access for live profiling → reasoning from source + heap-dump-style analysis is acceptable",
    "Recommended skill not-yet-authored → proceed with required skill + KB; surface gap in Notes"
  ],
  "_format": "Findings format + frontmatter contract: see packages/runtime/schema/_format-spec.md (v2.9.0 Phase B.1)"
