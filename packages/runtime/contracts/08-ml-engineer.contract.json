        "threshold": 0.6
      },
      "severity": "warn"
    },
    {
      "id": "A3",
      "check": "noTemplateRepetition",
      "args": {
        "minVariation": 0.3
      },
      "severity": "warn"
    },
    {
      "id": "A4",
      "check": "noPaddingPhrases",
