{
  "agentId": "actor-security-engineer",
  "persona": "12-security-engineer",
  "role": "actor",
  "skills": {
    "required": [
      "penetration-testing"
    ],
    "recommended": [
      "engineering:code-review",
      "engineering:incident-response",
      "legal:compliance-check",
      "security-audit",
      "cryptography",
      "iam",
      "compliance-frameworks"
    ],
    "skill_status": {
      "penetration-testing": "available",
      "engineering:code-review": "marketplace:knowledge-work-plugins/engineering",
      "engineering:incident-response": "marketplace:knowledge-work-plugins/engineering",
      "legal:compliance-check": "marketplace:knowledge-work-plugins/legal",
      "security-audit": "available",
      "cryptography": "not-yet-authored",
      "iam": "not-yet-authored",
      "compliance-frameworks": "not-yet-authored"
    }
  },
  "kb_scope": {
    "default": [
      "kb:security-dev/threat-modeling-essentials",
      "kb:security-dev/auth-patterns",
      "kb:hets/spawn-conventions"
    ]
  },
  "budget": {
    "tokens": 35000,
    "extensible": true,
    "maxExtensions": 1,
    "extensionAmount": 15000
  },
  "interface": {
    "traits": [
      "read_repo",
      "worktree_writable",
      "bash_test_runner",
      "recall_global"
    ],
    "declared_capabilities": {
      "read": [
        "repo://**"
      ],
      "isolation": "worktree",
      "write": [
        "sandbox://**"
      ],
      "subprocess": [
        "npm test",
        "vitest",
        "pytest",
        "tsc --noEmit"
      ],
      "read_recall": [
        "@library/*",
        "@thoughts/*"
      ]
    },
    "declared_scope": [
      "security vulnerability detection",
      "remediation + secure-default fixes",
      "auth/authz + crypto + IAM review",
      "threat modeling + principle audit"
    ],
    "output_schema": {
      "type": "security_findings",
      "required": [
        "severity_sections",
        "evidence",
        "file_citations",
        "principle_audit"
      ]
    },
    "decomposition_discipline": {
      "primary": "spec-driven",
      "fallback_when_code_producing": "tdd"
    },
    "instincts": [
      "threat-model-first",
      "least-privilege",
      "secret-handling",
      "input-validation-at-boundary",
      "transit-and-rest-protection",
      "defense-in-depth",
      "secure-by-default",
      "blast-radius-containment",
      "auditability",
      "realistic-severity",
      "error-handling-non-leakage"
    ]
  },
  "defaults": {
    "timeout": 1800,
    "retention": {
      "pre_snapshot_lifetime_hours": 24,
      "delta_lifetime_days": 30
    },
    "budget": {
      "tokens": 35000,
      "extensible": true,
      "maxExtensions": 1,
      "extensionAmount": 15000
    }
  },
  "functional": [
    {
      "id": "F1",
      "check": "outputContainsFrontmatter",
      "required": true
    },
    {
      "id": "F2",
      "check": "frontmatterHasFields",
      "args": {
        "fields": [
          "id",
          "role",
          "depth",
          "parent",
          "persona",
          "identity"
        ]
      },
      "required": true
    },
    {
      "id": "F3",
      "check": "minFindings",
      "args": {
        "min": 2
      },
      "required": true
    },
    {
      "id": "F4",
      "check": "hasFileCitations",
      "args": {
        "min": 4
      },
      "required": true
    },
    {
      "id": "F5",
      "check": "hasSeveritySections",
      "args": {
        "severities": [
          "CRITICAL",
          "HIGH",
          "MEDIUM",
          "LOW"
        ]
      },
      "required": true
    },
    {
      "id": "F6",
      "check": "containsKeywords",
      "args": {
        "keywords": [
          "threat"
        ]
      },
      "required": false
    },
    {
      "id": "F7",
      "check": "noUnrolledLoops",
      "args": {
        "maxRepetitions": 5
      },
      "required": true
    },
    {
      "id": "F8",
      "check": "noExcessiveNesting",
      "args": {
        "maxDepth": 4
      },
      "required": true
    },
    {
      "id": "F9",
      "check": "kb_scope_consumed",
      "required": true
    },
    {
      "id": "F10",
      "check": "containsKeywords",
      "args": {
        "keywords": [
          "Principle"
        ]
      },
      "required": false
    }
  ],
  "antiPattern": [
    {
      "id": "A1",
      "check": "claimsHaveEvidence",
      "severity": "fail"
    },
    {
      "id": "A2",
      "check": "noTextSimilarityToPriorRun",
      "args": {
        "threshold": 0.6
      },
      "severity": "warn"
    },
    {
      "id": "A3",
      "check": "noTemplateRepetition",
      "args": {
        "minVariation": 0.3
      },
      "severity": "warn"
    },
    {
      "id": "A4",
      "check": "noPaddingPhrases",
      "severity": "fail"
    },
    {
      "id": "A5",
      "check": "acknowledgesFallback",
      "severity": "warn"
    }
  ],
  "fallbackAcceptable": [
    "No live exploit testing → static analysis + reasoning about exploit paths from source is acceptable",
    "Recommended skill not-yet-authored → proceed with required skill + KB; surface gap in Notes"
  ],
  "_format": "Findings format + frontmatter contract: see packages/runtime/schema/_format-spec.md (v2.9.0 Phase B.1)"
}
