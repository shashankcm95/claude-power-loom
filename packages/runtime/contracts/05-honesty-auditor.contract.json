{
  "agentId": "actor-honesty-auditor",
  "persona": "05-honesty-auditor",
  "role": "actor",
  "skills": {
    "required": [
      "self-improve"
    ],
    "recommended": [
      "prune",
      "agent-team"
    ],
    "skill_status": {
      "self-improve": "available",
      "prune": "available",
      "agent-team": "available"
    }
  },
  "kb_scope": {
    "default": [
      "kb:hets/spawn-conventions"
    ]
  },
  "budget": {
    "tokens": 25000,
    "extensible": true,
    "maxExtensions": 1,
    "extensionAmount": 10000
  },
  "interface": {
    "traits": [
      "read_repo",
      "recall_global"
    ],
    "declared_capabilities": {
      "read": [
        "repo://**"
      ],
      "read_recall": [
        "@library/*",
        "@thoughts/*"
      ]
    },
    "declared_scope": [
      "claim-vs-evidence rating",
      "scorecard + debrief re-rating against artifacts",
      "transcript compliance audit",
      "optimistic-self-assessment detection"
    ],
    "output_schema": {
      "type": "honesty_audit",
      "required": [
        "compliance_assessment",
        "transcript_evidence"
      ]
    },
    "decomposition_discipline": {
      "primary": "spec-driven",
      "fallback_when_code_producing": "tdd"
    },
    "instincts": [
      "verified-vs-asserted",
      "overclaim-hunting",
      "evidence-or-it-did-not-happen",
      "negative-attestation",
      "stat-citation-provenance",
      "scope-of-claim-precision",
      "change-vs-reframe",
      "rater-drift",
      "hedge-honesty-optimism-default"
    ]
  },
  "defaults": {
    "timeout": 1800,
    "retention": {
      "pre_snapshot_lifetime_hours": 24,
      "delta_lifetime_days": 30
    },
    "budget": {
      "tokens": 25000,
      "extensible": true,
      "maxExtensions": 1,
      "extensionAmount": 10000
    }
  },
  "functional": [
    {
      "id": "F1",
      "check": "outputContainsFrontmatter",
      "required": true
    },
    {
      "id": "F2",
      "check": "frontmatterHasFields",
      "args": {
        "fields": [
          "id",
          "role",
          "depth",
          "parent",
          "persona"
        ]
      },
      "required": true
    },
    {
      "id": "F3",
      "check": "outputLengthMin",
      "args": {
        "min": 1500
      },
      "required": true
    },
    {
      "id": "F4",
      "check": "containsKeywords",
      "args": {
        "keywords": [
          "compliance",
          "transcript"
        ]
      },
      "required": true
    },
    {
      "id": "F5",
      "check": "kb_scope_consumed",
      "required": true
    }
  ],
  "antiPattern": [
    {
      "id": "A1",
      "check": "noTextSimilarityToPriorRun",
      "args": {
        "threshold": 0.55
      },
      "severity": "warn"
    },
    {
      "id": "A2",
      "check": "noPaddingPhrases",
      "severity": "fail"
    },
    {
      "id": "A3",
      "check": "acknowledgesFallback",
      "severity": "warn"
    }
  ],
  "fallbackAcceptable": [
    "Transcript too long → strategic sampling with explicit grep/jq commands is acceptable"
  ],
  "_format": "Findings format + frontmatter contract: see packages/runtime/schema/_format-spec.md (v2.9.0 Phase B.1)"
}
