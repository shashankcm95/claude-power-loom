{
  "agentId": "actor-ios-developer",
  "persona": "06-ios-developer",
  "role": "actor",
  "skills": {
    "required": [
      "swift-development"
    ],
    "recommended": [
      "engineering:debug",
      "engineering:testing-strategy",
      "engineering:deploy-checklist",
      "swiftui",
      "xcode-debugging",
      "app-store-deployment",
      "core-data"
    ],
    "skill_status": {
      "swift-development": "available",
      "engineering:debug": "marketplace:knowledge-work-plugins/engineering",
      "engineering:testing-strategy": "marketplace:knowledge-work-plugins/engineering",
      "engineering:deploy-checklist": "marketplace:knowledge-work-plugins/engineering",
      "swiftui": "not-yet-authored",
      "xcode-debugging": "not-yet-authored",
      "app-store-deployment": "not-yet-authored",
      "core-data": "not-yet-authored"
    }
  },
  "kb_scope": {
    "default": [
      "kb:mobile-dev/swift-essentials",
      "kb:mobile-dev/ios-app-architecture",
      "kb:hets/spawn-conventions"
    ]
  },
  "budget": {
    "tokens": 35000,
    "extensible": true,
    "maxExtensions": 1,
    "extensionAmount": 15000
  },
  "interface": {
    "traits": [
      "read_repo",
      "worktree_writable",
      "bash_test_runner",
      "recall_global"
    ],
    "declared_capabilities": {
      "read": [
        "repo://**"
      ],
      "isolation": "worktree",
      "write": [
        "sandbox://**"
      ],
      "subprocess": [
        "npm test",
        "vitest",
        "pytest",
        "tsc --noEmit"
      ],
      "read_recall": [
        "@library/*",
        "@thoughts/*"
      ]
    },
    "declared_scope": [
      "Swift + SwiftUI feature development",
      "Core Data + async/await iOS patterns",
      "Apple platform-convention adherence",
      "Xcode debugging"
    ],
    "output_schema": {
      "type": "implementation",
      "required": [
        "findings",
        "file_citations"
      ]
    },
    "decomposition_discipline": {
      "primary": "spec-driven",
      "fallback_when_code_producing": "tdd"
    },
    "instincts": [
      "value-semantics-first",
      "force-unwrap-paranoia",
      "retain-cycle-suspicion",
      "main-thread-ui-discipline",
      "structured-concurrency-over-legacy",
      "state-lifetime-correctness",
      "apple-convention-fidelity",
      "secret-handling-location",
      "accessibility-as-baseline",
      "app-store-survivability"
    ]
  },
  "defaults": {
    "timeout": 1800,
    "retention": {
      "pre_snapshot_lifetime_hours": 24,
      "delta_lifetime_days": 30
    },
    "budget": {
      "tokens": 35000,
      "extensible": true,
      "maxExtensions": 1,
      "extensionAmount": 15000
    }
  },
  "functional": [
    {
      "id": "F1",
      "check": "outputContainsFrontmatter",
      "required": true
    },
    {
      "id": "F2",
      "check": "frontmatterHasFields",
      "args": {
        "fields": [
          "id",
          "role",
          "depth",
          "parent",
          "persona",
          "identity"
        ]
      },
      "required": true
    },
    {
      "id": "F3",
      "check": "minFindings",
      "args": {
        "min": 2
      },
      "required": true
    },
    {
      "id": "F4",
      "check": "hasFileCitations",
      "args": {
        "min": 4
      },
      "required": true
    },
    {
      "id": "F5",
      "check": "hasSeveritySections",
      "args": {
        "severities": [
          "CRITICAL",
          "HIGH",
          "MEDIUM",
          "LOW"
        ]
      },
      "required": true
    },
    {
      "id": "F6",
      "check": "containsKeywords",
      "args": {
        "keywords": [
          "swift"
        ]
      },
      "required": false
    },
    {
      "id": "F7",
      "check": "noUnrolledLoops",
      "args": {
        "maxRepetitions": 5
      },
      "required": true
    },
    {
      "id": "F8",
      "check": "noExcessiveNesting",
      "args": {
        "maxDepth": 4
      },
      "required": true
    },
    {
      "id": "F9",
      "check": "kb_scope_consumed",
      "required": true
    }
  ],
  "antiPattern": [
    {
      "id": "A1",
      "check": "claimsHaveEvidence",
      "severity": "fail"
    },
    {
      "id": "A2",
      "check": "noTextSimilarityToPriorRun",
      "args": {
        "threshold": 0.6
      },
      "severity": "warn"
    },
    {
      "id": "A3",
      "check": "noTemplateRepetition",
      "args": {
        "minVariation": 0.3
      },
      "severity": "warn"
    },
    {
      "id": "A4",
      "check": "noPaddingPhrases",
      "severity": "fail"
    },
    {
      "id": "A5",
      "check": "acknowledgesFallback",
      "severity": "warn"
    }
  ],
  "fallbackAcceptable": [
    "No simulator / device → reasoning from source with file:line citations is acceptable",
    "Recommended skill not-yet-authored → proceed with required skill + KB; surface gap in Notes"
  ],
  "_format": "Findings format + frontmatter contract: see packages/runtime/schema/_format-spec.md (v2.9.0 Phase B.1)"
}
