{
  "agentId": "actor-confused-user",
  "persona": "02-confused-user",
  "role": "actor",
  "skills": {
    "required": [],
    "recommended": []
  },
  "kb_scope": {
    "default": [
      "kb:hets/spawn-conventions"
    ]
  },
  "budget": {
    "tokens": 25000,
    "extensible": true,
    "maxExtensions": 1,
    "extensionAmount": 10000
  },
  "interface": {
    "traits": [
      "read_repo"
    ],
    "declared_capabilities": {
      "read": [
        "repo://**"
      ]
    },
    "declared_scope": [
      "usability-adversary review",
      "documentation clarity from a newcomer lens",
      "error-message + UI-flow critique",
      "accuracy/false-claim detection"
    ],
    "output_schema": {
      "type": "usability_findings",
      "required": [
        "findings",
        "accuracy_assessment"
      ]
    },
    "decomposition_discipline": {
      "primary": "spec-driven",
      "fallback_when_code_producing": "tdd"
    }
  },
  "defaults": {
    "timeout": 1800,
    "retention": {
      "pre_snapshot_lifetime_hours": 24,
      "delta_lifetime_days": 30
    },
    "budget": {
      "tokens": 25000,
      "extensible": true,
      "maxExtensions": 1,
      "extensionAmount": 10000
    }
  },
  "functional": [
    {
      "id": "F1",
      "check": "outputContainsFrontmatter",
      "required": true
    },
    {
      "id": "F2",
      "check": "frontmatterHasFields",
      "args": {
        "fields": [
          "id",
          "role",
          "depth",
          "parent",
          "persona"
        ]
      },
      "required": true
    },
    {
      "id": "F3",
      "check": "minFindings",
      "args": {
        "min": 4
      },
      "required": true
    },
    {
      "id": "F4",
      "check": "containsKeywords",
      "args": {
        "keywords": [
          "accuracy",
          "false"
        ]
      },
      "required": true
    },
    {
      "id": "F5",
      "check": "outputLengthMin",
      "args": {
        "min": 1500
      },
      "required": true
    },
    {
      "id": "F6",
      "check": "kb_scope_consumed",
      "required": true
    }
  ],
  "antiPattern": [
    {
      "id": "A1",
      "check": "noTextSimilarityToPriorRun",
      "args": {
        "threshold": 0.6
      },
      "severity": "warn"
    },
    {
      "id": "A2",
      "check": "noPaddingPhrases",
      "severity": "fail"
    },
    {
      "id": "A3",
      "check": "acknowledgesFallback",
      "severity": "warn"
    }
  ],
  "fallbackAcceptable": [
    "Cannot run hook live → manual regex tracing of prompt-enrich-trigger.js is acceptable IF traced with file:line"
  ],
  "_format": "Findings format + frontmatter contract: see packages/runtime/schema/_format-spec.md (v2.9.0 Phase B.1)"
}
