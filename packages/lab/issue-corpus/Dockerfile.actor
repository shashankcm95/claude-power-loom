# loom-actor — the containment image for the ③.2.2b actor-write sandbox.
#
# Loom-AUTHORED, NOT attacker-influenced: the stranger supplies the repo + issue, never this Dockerfile.
# The actor (`claude -p`) runs IN here, write-confined to the bind-mounted /work clone (an out-of-/work
# write lands on the ephemeral container FS, never the host). UNLIKE the grade image (loom-sandbox,
# `--network none`, python+pytest), this image is node + the claude CLI and runs with NETWORK ON at run
# time (the actor must reach the Anthropic API). The API key is injected via `-e ANTHROPIC_API_KEY` at
# RUN time (never baked into the image).
#
# Contents: node + @anthropic-ai/claude-code ONLY. NO git (the clone is hardened on the HOST,
# pre-container, by _clone-lifecycle.js, and the diff is captured on the host AFTER the actor exits),
# NO python.
#
# Build (stdin context — sends ONLY this file, never the repo tree; there is no COPY):
#   docker build --provenance=false --sbom=false -t loom-actor:latest - < packages/lab/issue-corpus/Dockerfile.actor
#
# `--provenance=false --sbom=false` is REQUIRED (not cosmetic): on Docker 29.x with buildkit, the default
# attestation manifest makes the result an OCI index that `docker image inspect <tag>` cannot resolve, so
# the backend's `dockerImageExists` (which inspects by tag) would false-negative "image absent" and the
# actor would fail-closed-skip on a built image. The flags produce a classic single-manifest image.
#
# SUPPLY-CHAIN (VERIFY H6, mirrors the grade Dockerfile): the base is DIGEST-pinned and the claude CLI is
# VERSION-pinned. The build runs on the HOST with full network (a build-time surface DISTINCT from the
# run-time boundary). The pins below were resolved + frozen at first image build (the ③.2.2b dogfood:
# node:22-slim @ the digest below, claude-code 2.1.185). The actor backend fails-CLOSED with a build hint
# if the image is absent. To bump: re-resolve the digest/version, rebuild, re-run the containment spike + dogfood.

FROM node:22-slim@sha256:d9f850096136edbc402debdd8729579a288aac64574ada0ff4db26b6ae58b0b2

# The claude CLI (VERSION-pinned). --no-fund/--no-audit keep the layer lean + offline-quiet.
RUN npm install -g @anthropic-ai/claude-code@2.1.185 --no-fund --no-audit \
  && npm cache clean --force

# A writable HOME on the ephemeral tmpfs: the root fs is mounted --read-only at run time, so claude's
# writes to ~/.claude land on /tmp (the run-time --tmpfs), never the host.
ENV HOME=/tmp

# No ENTRYPOINT/CMD that interferes: the backend runs `<image> sh -c '<wrapper>' sh claude -p ...`,
# overriding the base CMD. The container runs as --user $(id -u):$(id -g) at RUN time (the host clone
# owner — keeps non-root AND able to write the bind-mounted /work), so no image-baked user is required.
