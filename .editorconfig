# EditorConfig — power-loom (H.7.8)
# https://editorconfig.org
#
# Ensures consistent indentation, line endings, and whitespace handling
# across editors. No build dep — most editors honor this natively.

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.{md,markdown}]
indent_size = 2
trim_trailing_whitespace = false  # markdown line breaks via trailing 2-space

[*.sh]
indent_size = 4

[Makefile]
indent_style = tab

[*.{yml,yaml,json}]
indent_size = 2
